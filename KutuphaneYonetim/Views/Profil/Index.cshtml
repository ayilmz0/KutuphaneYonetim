@model KutuphaneYonetim.Models.Profil

@{
    ViewData["Title"] = "Profilim";
}

@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    var rol = HttpContextAccessor.HttpContext.Session.GetString("Rol");
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="profil-sayfasi-container">

    <div class="ana-profil-karti">
        <div class="profil-banner"></div>
        <div class="profil-avatar">
            <img src="https://st5.depositphotos.com/83039852/70317/v/600/depositphotos_703179392-stock-illustration-user-account-icon-default-avatar.jpg" alt="Profil Resmi">
        </div>
        <div class="profil-temel-bilgi">
            <h2>@Model.AdSoyad</h2>
            <p>@Model.Rol</p>
        </div>
        <div class="profil-detaylar">
            <div class="detay-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                <span>@Model.Email</span>
            </div>
            <div class="detay-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                <span>Durum:<span class="durum-aktif"> @(Model.Durum ? "Aktif" : "Kullanılmıyor")</span></span>
            </div>
            @if (rol == "Üye")
            {
                <div class="detay-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    <span>Kayıt: @(Model.KayitTarihi != DateTime.MinValue ? Model.KayitTarihi?.ToShortDateString() : "Bilinmiyor")</span>
                </div>
            }
            </div>
    </div>
</div>

<style>
    :root {
        --arkaplan: #f8fafc;
        --kart-arkaplan: #ffffff;
        --ana-yazi: #1e293b;
        --ikincil-yazi: #64748b;
        --golge: rgba(149, 157, 165, 0.1);
        --sinir: #e2e8f0;
        --banner-renk: rgb(17 24 39);
    }

    body {
        font-family: 'Poppins', sans-serif;
        background-color: var(--arkaplan);
        color: var(--ana-yazi);
        padding: 40px 20px;
    }

    .profil-sayfasi-container {
        max-width: 900px;
        margin: 0 auto;
        display: grid;
        gap: 30px;
    }

    .ana-profil-karti {
        background-color: var(--kart-arkaplan);
        border-radius: 16px;
        box-shadow: 0 8px 24px var(--golge);
        border: 1px solid var(--sinir);
        text-align: center;
        padding-bottom: 30px;
        position: relative;
        overflow: hidden;
    }

    .profil-banner {
        background-color: var(--banner-renk);
        height: 120px;
    }

    .profil-avatar {
        margin-top: -60px;
        position: relative;
    }

        .profil-avatar img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 5px solid var(--kart-arkaplan);
            background-color: var(--kart-arkaplan);
        }

    .profil-temel-bilgi {
        margin-top: 15px;
    }

        .profil-temel-bilgi h2 {
            font-size: 1.75rem;
            font-weight: 700;
            margin: 0;
        }

        .profil-temel-bilgi p {
            color: var(--ikincil-yazi);
            margin: 4px 0 0 0;
            font-weight: 500;
        }

    .profil-detaylar {
        margin-top: 25px;
        padding: 0 30px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
        text-align: left;
    }

    .detay-item {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #334155;
        font-size: 0.95rem;
        font-weight: bold;
    }

        .detay-item svg {
            color: var(--ikincil-yazi);
        }

    .durum-aktif {
        font-weight: 600;
        color: #22c55e;
    }

    .istatistik-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 25px;
    }

    .istatistik-karti {
        background-color: var(--kart-arkaplan);
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        border: 1px solid var(--sinir);
        box-shadow: 0 8px 24px var(--golge);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .kart-ikon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px auto;
    }

    .istatistik-karti h3 {
        font-size: 1rem;
        color: var(--ikincil-yazi);
        margin: 0 0 5px 0;
        font-weight: 500;
    }

    .istatistik-karti p {
        font-size: 2.25rem;
        font-weight: 700;
        margin: 0;
        line-height: 1.1;
    }

        .istatistik-karti p.kucuk-yazi {
            font-size: 1.1rem;
            font-weight: 600;
            min-height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
</style>